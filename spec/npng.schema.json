{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nextpng.org/schema/npng.schema.json",
  "title": "nextPNG document",
  "description": "Schema for npng YAML vector graphics documents.",
  "type": "object",
  "required": ["npng", "canvas", "layers"],
  "additionalProperties": true,
  "properties": {
    "npng": {
      "type": "string",
      "enum": ["0.3", "0.4"]
    },
    "canvas": {
      "type": "object",
      "required": ["width", "height"],
      "additionalProperties": true,
      "properties": {
        "width": { "type": "number", "minimum": 1 },
        "height": { "type": "number", "minimum": 1 },
        "background": { "type": "string" }
      }
    },
    "defs": {
      "type": "array",
      "items": { "$ref": "#/$defs/element" }
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "master"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "master": { "$ref": "#/$defs/element" },
          "properties": { "type": "object" }
        },
        "additionalProperties": true
      }
    },
    "layers": {
      "type": "array",
      "items": { "$ref": "#/$defs/layer" }
    }
  },
  "$defs": {
    "colorOrPaint": {
      "oneOf": [
        { "type": "string" },
        { "$ref": "#/$defs/gradient" },
        { "type": "null" }
      ]
    },
    "gradient": {
      "type": "object",
      "required": ["type", "stops"],
      "properties": {
        "type": { "enum": ["linear-gradient", "radial-gradient"] },
        "x1": { "type": "number" },
        "y1": { "type": "number" },
        "x2": { "type": "number" },
        "y2": { "type": "number" },
        "cx": { "type": "number" },
        "cy": { "type": "number" },
        "r": { "type": "number" },
        "stops": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["offset", "color"],
            "properties": {
              "offset": { "type": "number", "minimum": 0, "maximum": 1 },
              "color": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "stroke": {
      "type": "object",
      "properties": {
        "color": { "type": "string" },
        "width": { "type": "number", "minimum": 0 },
        "dash": {
          "type": "array",
          "items": { "type": "number" }
        },
        "cap": { "enum": ["butt", "round", "square"] },
        "join": { "enum": ["miter", "round", "bevel"] }
      },
      "additionalProperties": true
    },
    "layer": {
      "type": "object",
      "required": ["elements"],
      "properties": {
        "name": { "type": "string" },
        "visible": { "type": "boolean" },
        "locked": { "type": "boolean" },
        "opacity": { "type": "number", "minimum": 0, "maximum": 1 },
        "blend_mode": { "$ref": "#/$defs/blendMode" },
        "filters": {
          "type": "array",
          "items": { "$ref": "#/$defs/filter" }
        },
        "clip_path": { "type": "string" },
        "mask": { "type": "string" },
        "elements": {
          "type": "array",
          "items": { "$ref": "#/$defs/element" }
        }
      },
      "additionalProperties": true
    },
    "element": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "enum": ["rect", "ellipse", "line", "text", "path", "group", "boolean", "use", "image", "frame", "component-instance"]
        },
        "id": { "type": "string" },
        "name": { "type": "string" },
        "visible": { "type": "boolean" },
        "locked": { "type": "boolean" },
        "opacity": { "type": "number", "minimum": 0, "maximum": 1 },
        "blend_mode": { "$ref": "#/$defs/blendMode" },
        "fill": { "$ref": "#/$defs/colorOrPaint" },
        "stroke": { "$ref": "#/$defs/stroke" },
        "filters": {
          "type": "array",
          "items": { "$ref": "#/$defs/filter" }
        },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "width": { "type": "number" },
        "height": { "type": "number" },
        "cx": { "type": "number" },
        "cy": { "type": "number" },
        "rx": { "type": "number" },
        "ry": { "type": "number" },
        "x1": { "type": "number" },
        "y1": { "type": "number" },
        "x2": { "type": "number" },
        "y2": { "type": "number" },
        "d": { "type": "string" },
        "content": { "type": "string" },
        "font_size": { "type": "number" },
        "font_family": { "type": "string" },
        "font_weight": { "type": ["string", "number"] },
        "align": { "enum": ["left", "center", "right"] },
        "elements": {
          "type": "array",
          "items": { "$ref": "#/$defs/element" }
        },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/element" }
        },
        "href": { "type": "string" },
        "ref": { "type": "string" },
        "component_id": { "type": "string" }
      },
      "additionalProperties": true
    },
    "filter": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "enum": ["blur", "drop-shadow"] },
        "radius": { "type": "number" },
        "dx": { "type": "number" },
        "dy": { "type": "number" },
        "color": { "type": "string" }
      },
      "additionalProperties": true
    },
    "blendMode": {
      "enum": ["normal", "multiply", "screen", "overlay", "darken", "lighten", "color-dodge", "color-burn", "hard-light", "soft-light", "difference", "exclusion"]
    }
  }
}
